# Analytics / Marketing Pixels
# Leave blank to disable. No scripts load unless an ID is provided.
VITE_GA4_ID=
VITE_META_PIXEL_ID=

# Google Sheet Webhook (contact form submissions)
VITE_SHEET_WEBHOOK_URL=

# Admin panel legacy password (only used if Firebase is not configured below)
VITE_ADMIN_PASSWORD=mineworld2025

# Firebase (admin panel backend — Auth + Firestore)
# Get these from Firebase Console → Project settings → Your apps → Web app config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Cloudinary (CMS asset hosting — Phase 1)
# Frontend (safe to expose):
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_API_KEY=
VITE_CLOUDINARY_UPLOAD_PRESET=mineworld_assets
# Backend only (used by api/cloudinary-delete.js — NEVER prefix with VITE_):
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
